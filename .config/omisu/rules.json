[
    {
        "cmds": [
            "tmux display-message -d 5000 \"$app_name | $summary | $body\""
        ],
        "filters": {}
    },

    {
        "cmds": [
            "mpv --volume=50 $SARBS/sounds/win95/DA_MAX.WAV >/dev/null &"
        ],
        "filters": {
            "summary": "sxhkd"
        }
    },

    {
        "cmds": [
            "mpv --volume=50 $SARBS/sounds/win95/DA_ERROR.WAV >/dev/null &"
        ],
        "filters": {
            "app_name": "discord"
        }
    }

]
