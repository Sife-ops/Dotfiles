# Global properties
separator=true
separator_block_width=15

[iface]
command=i3_iface
LABEL=wlan0:
IFACE=wlan0
#ADDRESS_FAMILY=inet6?
color=#00FF00
interval=10

[memory]
command=i3_memory
label=MEM
interval=30

[cpu_usage]
command=i3_cpu_usage
interval=10
LABEL=CPU:
#min_width=CPU: 100.00%
#T_WARN=50
#T_CRIT=80
#DECIMALS=2

[time]
command=date '+%Y-%m-%d %H:%M:%S'
interval=1

